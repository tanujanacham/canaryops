# ── Kubernetes ──────────────────────────────────────────────
# Path to your kubeconfig file (defaults to ~/.kube/config if omitted)
KUBECONFIG_PATH=/home/youruser/.kube/config

# Namespace where your stable + canary Deployments live
K8S_NAMESPACE=default

# Label selector to identify your app's pods (e.g. "app=my-nextjs-app")
K8S_POD_SELECTOR=app=my-nextjs-app

# Names of the two Deployments
K8S_STABLE_DEPLOYMENT=stable-deployment
K8S_CANARY_DEPLOYMENT=canary-deployment

# ── AWS CloudWatch ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# Comma-separated list of CloudWatch alarm names to monitor
CW_ALARM_NAMES=CanaryErrorRate,CanaryLatencyP99,CanaryCPUSpike

# ── Server ───────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
